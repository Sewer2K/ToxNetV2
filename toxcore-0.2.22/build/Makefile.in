	$(srcdir)/../toxcore/Makefile.inc \
	$(srcdir)/../toxencryptsave/Makefile.inc $(srcdir)/Makefile.in \
	$(top_srcdir)/configure_aux/depcomp \
	$(top_srcdir)/configure_aux/test-driver
DISTFILES = $(DIST_COMMON) $(DIST_SOURCES) $(TEXINFOS) $(EXTRA_DIST)
